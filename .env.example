# Database (Railway managed Postgres)
DATABASE_URL=postgresql://user:password@host:5432/engram

# Encryption — 32-byte hex key for AES-256-GCM
ENCRYPTION_KEY=your_64_hex_chars_here

# ElevenLabs Scribe v2
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# LLM provider (OpenAI)
OPENAI_API_KEY=your_openai_api_key_here
LLM_MODEL=gpt-5.4-mini-2026-03-17

# Cloudflare R2 / S3-compatible storage
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_r2_access_key_id_here
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key_here
R2_BUCKET=engram

# Better Auth
BETTER_AUTH_SECRET=your_better_auth_secret_here
BETTER_AUTH_URL=http://localhost:3000

# Public app URL (must match BETTER_AUTH_URL; used by the auth client on the browser)
NEXT_PUBLIC_APP_URL=http://localhost:3000
